<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="view_whatsapp_wizard_form" model="ir.ui.view">
        <field name="name">whatsapp.wizard.form</field>
        <field name="model">whatsapp.wizard</field>
        <field name="arch" type="xml">
            <form string="Choose Number">
                <group>
                    <field name="phone_number"/>
                    <field name="phone_type"/>
                    <field name="message"/>
                </group>
                <footer>
                    <button name="action_call" type="object" string="Send Message" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
        </record>
    </data>
</odoo>