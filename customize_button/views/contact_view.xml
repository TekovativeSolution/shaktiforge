<?xml version="1.0"?>
<odoo>
    <!-- Inherit the existing form view of res.partner (contact form) -->
    <record id="res_partner_view_form_inherit" model="ir.ui.view">
        <field name="name">res.partner.form.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
          <xpath expr="//div[@class='oe_button_box']" position="before">
            <button name="action_phone_call" type="object" icon="fa-phone" class="mobile_btn btn btn-outline-primary ml4 mb4"/>
            <button name="action_send_whatsapp" type="object" icon="fa-whatsapp" class="mobile_btn btn btn-outline-primary ml4 mb4"/>
          </xpath>
        </field>
    </record>
</odoo>

