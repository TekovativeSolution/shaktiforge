<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="custom_mrp_res_config_settings_view_form" model="ir.ui.view">
            <field name="name">custom.mrp.res.config.settings.view.form.inherit.stock</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="30"/>
            <field name="inherit_id" ref="mrp.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//app[@name='mrp']/block[1]" position="inside">
                    <setting>
                        <field name="show_customer_info"/>
                    </setting>
                </xpath>
            </field>
        </record>
    </data>
</odoo>