<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="sale_order_line_tree_view" model="ir.ui.view">
        <field name="name">sale.order.line.tree.view</field>
        <field name="model">sale.order.line</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="order_id" readonly="1"/>
                <field name="partner_id" readonly="1"/>
                <field name="product_id" readonly="1"/>
                <field name="name" readonly="1"/>
                <field name="product_uom_qty" readonly="1"/>
                <field name="actual_qty"/>
                <field name="to_order"/>
                <field name="commitment_date"/>
                <field name="attachment"/>
                <field name="production_status"/>
                <button name="action_create_mo"
                    string="Create Order"
                    type="object"
                    class="btn-primary"
                    icon="fa-truck"/>
            </tree>
        </field>
    </record>


    <record id="sale_order_line_search" model="ir.ui.view">
        <field name="name">sale.order.line.search</field>
        <field name="model">sale.order.line</field>
        <field name="arch" type="xml">
            <search string="Production Planning">
                <field name="name"/>
                <field name="order_id"/>
                <field name="product_id"/>
                <filter string="Sale Order" name="sale_order" domain="[('state', '=', 'sale')]"/>
                <filter string="Production Status" name="production_state"
                        domain="[('production_status', '=', 'pending')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_state"
                            string="State"
                            context="{'group_by': 'state'}" domain="[('state','=','sale')]"
                    />

                </group>
            </search>
        </field>
    </record>

    <record id="action_production_planning" model="ir.actions.act_window">
        <field name="name">Production Planning</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">sale.order.line</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="sale_order_line_tree_view"/>
        <field name="search_view_id" ref="sale_order_line_search"/>
        <field name="context">{'search_default_production_state': 1}</field>
        <field name="domain">[('state','=','sale')]</field>
    </record>

    <menuitem id="production_planning_menu"
              name="Production Planning"
              action="action_production_planning"
              parent="mrp.menu_mrp_reporting"
              sequence="10"
    />


</odoo>