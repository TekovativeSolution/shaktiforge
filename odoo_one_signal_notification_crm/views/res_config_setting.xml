<?xml version="1.0" encoding="utf-8"?>
<odoo>
<record id="crm_config_inherit_view" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.crm</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="crm.res_config_settings_view_form"/>
            <field name="priority" eval="4"/>
            <field name="arch" type="xml">
                <xpath expr="//app/block[@name='generate_lead_setting_container']" position="after">
                    <block name="is_import_notification_required">
                    <setting id="is_import_notification_required" help="When this checkbox is checked then user will start receiving notification on assign of lead." string="Lead Import Notification" >
                            <field name="is_import_notification_required"/>
                        </setting>
                    </block>


               </xpath>
            </field>
        </record>
</odoo>