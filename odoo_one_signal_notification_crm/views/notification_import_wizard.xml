<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="notification_import_wizard_inherit_view" model="ir.ui.view">
        <field name="name">notification.import.wizard.view.form</field>
        <field name="model">notification.import.wizard</field>
        <field name="priority" eval="4"/>
        <field name="arch" type="xml">
            <form string="Notification Import">

                <group>
                    <field name="is_import_notification_required"/>
                </group>
                <footer>
                    <button name="set_import_notification" string="Set" class="oe_highlight" type="object"/>
                    or
                    <button special="cancel" string="Cancel" class="oe_link"/>
                </footer>
            </form>
        </field>
    </record>

     <record id="action_notification_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Notification</field>
        <field name="res_model">notification.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_notification_import" name="Import Notification Setting"
              sequence="10"
              action="action_notification_import_wizard"
              parent="crm.crm_menu_config"/>

</odoo>