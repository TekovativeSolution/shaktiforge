<odoo>
  <data>
      <record id="mail_activity_schedule_inherit_form_view" model="ir.ui.view">
			<field name="name">Mail Activity Schedule</field>
			<field name="model">mail.activity.schedule</field>
			<field name="inherit_id" ref="mail.mail_activity_schedule_view_form"/>
			<field name="arch" type="xml">
				<xpath expr="//field[@name='date_deadline']" position="attributes">
					 <attribute name="invisible">1</attribute>
				</xpath>
				<xpath expr="//field[@name='date_deadline']" position="after">
					<field name="date_due"/>
					<label for="interval_number" invisible="1"/>
					<div class="o_row" invisible="1">
						<field name="interval_type" class="oe_inline"/>
						<field name="interval_number" class="oe_inline"/>
					</div>

				</xpath>
<!--				<xpath expr="//field[@name='activity_user_id']" position="after">-->

<!--					<field name="date_due"/>-->
<!--					<label for="interval_number"/>-->
<!--					<div class="o_row">-->
<!--						<field name="interval_type" class="oe_inline"/>-->
<!--						<field name="interval_number" class="oe_inline"/>-->
<!--					</div>-->
<!--				</xpath>-->
			</field>
      </record>
  </data>

</odoo>
