<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
	<data>
		<record id="activity_reminder_form_view" model="ir.ui.view">
			<field name="name">activity.reminder.form.view</field>
			<field name="model">activity.reminder</field>
			<field name="arch" type="xml">
				<form create="0" edit="0">
					<sheet>
						<group>
							<group>
								<field name="activity_type_id"/>
								<field name="summary"/>
								<field name="is_done" readonly="1"/>
								<field name="record_id" readonly="1"/>
								<field name="model_name" readonly="1"/>
								<field name="reminder_datetime" readonly="1"/>
								<field name="activity" readonly="1"/>
							</group>
							<group>
								<field name="date_due"/>
								<label for="interval_no"/>
								<div class="o_row">
									<field name="interval_type" class="oe_inline"/>
									<field name="interval_no" class="oe_inline"/>
								</div>
								<field name="send_mail"/>
								<field name="send_sms"/>
								<field name="user_id"/>
							</group>
						</group>
					</sheet>
				</form>
			</field>
	  	</record>

		<record id="activity_reminder_tree_view" model="ir.ui.view">
		<field name="name">activity.reminder.tree.view</field>
		<field name="model">activity.reminder</field>
		<field name="arch" type="xml">
			<tree create="0">
				<field name="activity"/>
				<field name="activity_type_id"/>
				<field name="summary"/>
				<field name="user_id"/>
				<field name="date_due"/>
			</tree>
		</field>
		</record>

		<record id="activity_reminder_action_id" model="ir.actions.act_window">
			<field name="name">Activity Reminder</field>
			<field name="res_model">activity.reminder</field>
			<field name="view_mode">tree,form</field>
		</record>

		<record id="action_contact_reminder" model="ir.actions.act_window">
			<field name="name">Activity Reminder</field>
			<field name="res_model">activity.reminder</field>
			<field name="domain">[('model_name','=','res.partner')]</field>
			<field name="view_mode">tree,form</field>
		</record>

		<record id="action_sale_reminder" model="ir.actions.act_window">
			<field name="name">Activity Reminder</field>
			<field name="res_model">activity.reminder</field>
			<field name="domain">[('model_name','=','sale.order')]</field>
			<field name="view_mode">tree,form</field>
		</record>

		<record id="action_account_reminder" model="ir.actions.act_window">
			<field name="name">Activity Reminder</field>
			<field name="res_model">activity.reminder</field>
			<field name="domain">[('model_name','=','account.move')]</field>
			<field name="view_mode">tree,form</field>
		</record>

		<record id="action_project_reminder" model="ir.actions.act_window">
			<field name="name">Activity Reminder</field>
			<field name="res_model">activity.reminder</field>
			<field name="domain">[('model_name','=','project.task')]</field>
			<field name="view_mode">tree,form</field>
		</record>

		<record id="action_helpdesk_reminder" model="ir.actions.act_window">
			<field name="name">Activity Reminder</field>
			<field name="res_model">activity.reminder</field>
			<field name="domain">[('model_name','=','helpdesk.ticket')]</field>
			<field name="view_mode">tree,form</field>
		</record>

		<record id="action_note_reminder" model="ir.actions.act_window">
			<field name="name">Activity Reminder</field>
			<field name="res_model">activity.reminder</field>
			<field name="domain">[('model_name','=','note.note')]</field>
			<field name="view_mode">tree,form</field>
		</record>

  </data>
</odoo>