<?xml version="1.0" encoding="utf-8"?>
<odoo>
<record id="activity_reminder_inherit_view_id" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.crm</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
            <field name="priority" eval="4"/>
            <field name="arch" type="xml">
                <xpath expr="//app[@name='general_settings']/block[@name='performance']" position="after">
                    <block name="activity_reminder_before">
                        <setting id="reminder_before" string="Activity Remainder Before" >
                            <field name="reminder_before"/>
                        </setting>
                    </block>
               </xpath>
            </field>
        </record>
</odoo>

