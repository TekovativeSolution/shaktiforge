<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shakti_size2_tree" model="ir.ui.view">
        <field name="name">shakti.size2.tree</field>
        <field name="model">shakti.size2</field>
        <field name="arch" type="xml">
            <tree string="Size 2" editable="bottom">
                <field name="name"/>
                <field name="code"/>
            </tree>
        </field>
    </record>

    <record id="view_shakti_size2_form" model="ir.ui.view">
        <field name="name">shakti.size2.form</field>
        <field name="model">shakti.size2</field>
        <field name="arch" type="xml">
            <form string="Size 2">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_shakti_size2" model="ir.actions.act_window">
        <field name="name">Size 2</field>
        <field name="res_model">shakti.size2</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_shakti_size2"
        name="Size 2"
        parent="sale.menu_sale_config"
        action="action_shakti_size2"
        sequence="64"/>
</odoo>