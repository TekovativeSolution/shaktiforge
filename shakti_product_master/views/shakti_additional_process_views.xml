<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shakti_additional_process_tree" model="ir.ui.view">
        <field name="name">shakti.additional.process.tree</field>
        <field name="model">shakti.additional.process</field>
        <field name="arch" type="xml">
            <tree string="Additional Process" editable="bottom">
                <field name="name"/>
                <field name="code"/>
            </tree>
        </field>
    </record>

    <record id="view_shakti_additional_process_form" model="ir.ui.view">
        <field name="name">shakti.additional.process.form</field>
        <field name="model">shakti.additional.process</field>
        <field name="arch" type="xml">
            <form string="Additional Process">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_shakti_additional_process" model="ir.actions.act_window">
        <field name="name">Additional Process</field>
        <field name="res_model">shakti.additional.process</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_shakti_additional_process"
        name="Additional Process"
        parent="sale.menu_sale_config"
        action="action_shakti_additional_process"
        sequence="72"/>
</odoo>