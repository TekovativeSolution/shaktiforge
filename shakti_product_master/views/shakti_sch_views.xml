<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shakti_sch_tree" model="ir.ui.view">
        <field name="name">shakti.sch.tree</field>
        <field name="model">shakti.sch</field>
        <field name="arch" type="xml">
            <tree string="SCH" editable="bottom">
                <field name="name"/>
                <field name="code"/>
            </tree>
        </field>
    </record>

    <record id="view_shakti_sch_form" model="ir.ui.view">
        <field name="name">shakti.sch.form</field>
        <field name="model">shakti.sch</field>
        <field name="arch" type="xml">
            <form string="SCH">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_shakti_sch" model="ir.actions.act_window">
        <field name="name">SCH</field>
        <field name="res_model">shakti.sch</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_shakti_sch"
        name="SCH"
        parent="sale.menu_sale_config"
        action="action_shakti_sch"
        sequence="68"/>
</odoo>