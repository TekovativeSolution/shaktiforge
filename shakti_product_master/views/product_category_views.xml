<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shakti_category_tree" model="ir.ui.view">
        <field name="name">shakti.category.tree</field>
        <field name="model">shakti.category</field>
        <field name="arch" type="xml">
            <tree string="Category" editable="bottom">
                <field name="name"/>
                <field name="code"/>
                <field name="field_sequence" string="Field Sequence"/>
            </tree>
        </field>
    </record>

    <record id="view_shakti_category_form" model="ir.ui.view">
        <field name="name">shakti.category.form</field>
        <field name="model">shakti.category</field>
        <field name="arch" type="xml">
            <form string="Category">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="field_sequence"
                               string="Field Sequence"
                               placeholder="e.g. 2,3,7,5"
                               help="Enter Sr. Numbers separated by comma.&#10;1=Process Code | 2=Size 1 | 3=Size 2 | 4=Item Group | 5=End Connection | 6=Pressure Rating | 7=SCH | 8=Material Grade | 9=Die Code | 10=Customer Code | 11=Additional Process | 12=Fitting Standard"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_shakti_category" model="ir.actions.act_window">
        <field name="name">Category</field>
        <field name="res_model">shakti.category</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_shakti_category"
        name="Category"
        parent="sale.menu_sale_config"
        action="action_shakti_category"
        sequence="61"/>

</odoo>