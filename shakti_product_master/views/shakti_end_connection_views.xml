<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shakti_end_connection_tree" model="ir.ui.view">
        <field name="name">shakti.end.connection.tree</field>
        <field name="model">shakti.end.connection</field>
        <field name="arch" type="xml">
            <tree string="End Connection Type" editable="bottom">
                <field name="name"/>
                <field name="code"/>
            </tree>
        </field>
    </record>

    <record id="view_shakti_end_connection_form" model="ir.ui.view">
        <field name="name">shakti.end.connection.form</field>
        <field name="model">shakti.end.connection</field>
        <field name="arch" type="xml">
            <form string="End Connection Type">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_shakti_end_connection" model="ir.actions.act_window">
        <field name="name">End Connection Type</field>
        <field name="res_model">shakti.end.connection</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_shakti_end_connection"
        name="End Connection Type"
        parent="sale.menu_sale_config"
        action="action_shakti_end_connection"
        sequence="66"/>
</odoo>