<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shakti_size1_tree" model="ir.ui.view">
        <field name="name">shakti.size1.tree</field>
        <field name="model">shakti.size1</field>
        <field name="arch" type="xml">
            <tree string="Size 1" editable="bottom">
                <field name="name"/>
                <field name="code"/>
            </tree>
        </field>
    </record>

    <record id="view_shakti_size1_form" model="ir.ui.view">
        <field name="name">shakti.size1.form</field>
        <field name="model">shakti.size1</field>
        <field name="arch" type="xml">
            <form string="Size 1">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_shakti_size1" model="ir.actions.act_window">
        <field name="name">Size 1</field>
        <field name="res_model">shakti.size1</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_shakti_size1"
        name="Size 1"
        parent="sale.menu_sale_config"
        action="action_shakti_size1"
        sequence="63"/>
</odoo>